        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="1b50d" binding="contentRicerca" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
