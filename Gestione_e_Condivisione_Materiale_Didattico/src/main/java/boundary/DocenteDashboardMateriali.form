        </children>
      </scrollpane>
      <grid id="dbbf2" binding="contentAggiungi" layout-manager="GridLayoutManager" row-count="1" column-count="4" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
